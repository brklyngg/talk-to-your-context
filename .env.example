# Talk to Your Context - example environment.
# Copy to `.env` and fill in. Never commit `.env`.

# --- OpenAI Realtime ---------------------------------------------------------
# Used to mint ephemeral session keys server-side; the browser never sees this.
OPENAI_API_KEY=
# gpt-realtime-2 (May 2026 GA): GPT-5-class reasoning, 128K context, native
# preambles + async function calling. Use the legacy `gpt-realtime` only if you
# need to roll back to the pre-cutover behavior.
OPENAI_REALTIME_MODEL=gpt-realtime-2
OPENAI_REALTIME_VOICE=alloy

# --- Backend agent -----------------------------------------------------------
# Where this sidecar should reach your agent's chat-completions endpoint.
# Default points at a loopback service on the same host. Used by both
# /api/ask-agent (Realtime tool dispatch) and /api/text-turn (text-mode).
AGENT_API_BASE=http://127.0.0.1:8642
# Bearer token for the agent. Alternative: drop the key into a sibling file
# called `.agent-api-key` (chmod 600) and leave this blank.
AGENT_API_KEY=

# --- Sidecar listener --------------------------------------------------------
VOICE_HOST=127.0.0.1
VOICE_PORT=8090
# Comma-separated CIDR allowlist. Default is loopback only.
# Example for Tailscale CGNAT: 100.64.0.0/10,127.0.0.1/32,::1/128
VOICE_ALLOWED_CIDR=127.0.0.1/32,::1/128

# --- ask_agent timeout -------------------------------------------------------
# Total wall-clock cap on a single ask_agent forward to the backend. The model
# itself fills the wait via native preambles + async function calling, so this
# only bounds the absolute worst case (Hermes hung, network wedged, etc.).
ASK_AGENT_TIMEOUT_SEC=90

# --- Transcripts -------------------------------------------------------------
TRANSCRIPT_DIR=./transcripts

# --- Optional: Slack archive of voice calls ----------------------------------
# Leave blank to disable. If set, each ended call posts a headline + threaded
# transcript to the configured channel.
SLACK_BOT_TOKEN=
SLACK_CALL_CHANNEL_ID=
